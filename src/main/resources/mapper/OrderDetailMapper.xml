<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="demo3.demo3_068.mapper.OrderDetailMapper">

    <resultMap id="OrderDetailResultMap" type="demo3.demo3_068.entity.OrderDetail">
        <id column="id" property="id"/>
        <result column="order_id" property="orderId"/>
        <result column="dish_id" property="dishId"/>
        <result column="dish_name" property="dishName"/>
        <result column="dish_price" property="dishPrice"/>
        <result column="quantity" property="quantity"/>
        <result column="amount" property="amount"/>
    </resultMap>

    <select id="selectByOrderId" resultMap="OrderDetailResultMap">
        select id, order_id, dish_id, dish_name, dish_price, quantity, amount
        from order_detail
        where order_id = #{orderId}
        order by id asc
    </select>

    <insert id="insertBatch">
        insert into order_detail (order_id, dish_id, dish_name, dish_price, quantity, amount)
        values
        <foreach collection="details" item="detail" separator=",">
            (#{detail.orderId}, #{detail.dishId}, #{detail.dishName}, #{detail.dishPrice},
             #{detail.quantity}, #{detail.amount})
        </foreach>
    </insert>
</mapper>
