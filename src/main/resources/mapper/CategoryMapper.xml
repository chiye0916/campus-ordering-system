<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="demo3.demo3_068.mapper.CategoryMapper">

    <resultMap id="CategoryResultMap" type="demo3.demo3_068.entity.Category">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="sort" property="sort"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="selectById" resultMap="CategoryResultMap">
        select id, name, sort, create_time, update_time
        from category
        where id = #{id}
    </select>

    <select id="selectByName" resultMap="CategoryResultMap">
        select id, name, sort, create_time, update_time
        from category
        where name = #{name}
    </select>

    <select id="selectByNameExcludeId" resultMap="CategoryResultMap">
        select id, name, sort, create_time, update_time
        from category
        where name = #{name}
          and id != #{id}
    </select>

    <select id="selectAllOrderBySort" resultMap="CategoryResultMap">
        select id, name, sort, create_time, update_time
        from category
        order by sort asc, id asc
    </select>

    <insert id="insert" parameterType="demo3.demo3_068.entity.Category"
            useGeneratedKeys="true" keyProperty="id">
        insert into category (name, sort)
        values (#{name}, #{sort})
    </insert>

    <update id="updateById" parameterType="demo3.demo3_068.entity.Category">
        update category
        set name = #{name},
            sort = #{sort}
        where id = #{id}
    </update>

    <delete id="deleteById">
        delete from category
        where id = #{id}
    </delete>
</mapper>
